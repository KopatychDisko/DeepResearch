# LLM providers (set at least one)
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Optional: override default model (openai:gpt-5-mini)
# LLM_MODEL=openrouter:openai/gpt-5-mini

# Search
TAVILY_API_KEY=

# HH.ru public API (optional; website fallback works when api.hh.ru returns 403)
# Register at https://dev.hh.ru/ and use format: AppName/1.0 (you@email.com)
HH_API_USER_AGENT=

# Optional observability (Langfuse v4 reads credentials from env)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
# Deprecated alias; LANGFUSE_BASE_URL is preferred
LANGFUSE_HOST=
# Optional release label shown in Langfuse UI
LANGFUSE_RELEASE=employer-dd-agent@0.1.0
